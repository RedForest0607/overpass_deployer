#!/bin/bash
# Generated by go-deployer — do not edit manually

APP_NAME="{{ .AppName }}"
JAR_PATH="{{ .JarPath }}"
BASE_DIR="{{ .BaseDir }}"
LOG_DIR="${BASE_DIR}/logs"
PID_FILE="${BASE_DIR}/run/${APP_NAME}.pid"
PORT="{{ .Port }}"
SCRIPT_NAME="$(basename "$0")"

JAVA_OPTS=(
  "-Xms{{ .JvmMin }}"
  "-Xmx{{ .JvmMax }}"
  "-Dserver.port=${PORT}"
{{- range .JavaOpts }}
  "{{ . }}"
{{- end }}
{{- range .ExtraOpts }}
  "{{ . }}"
{{- end }}
)

print_usage() {
  echo "Usage: ./server.sh <start|stop>"
}

resolve_command() {
  if [ $# -gt 0 ]; then
    echo "$1"
    return
  fi

  case "${SCRIPT_NAME}" in
    start.sh)
      echo "start"
      ;;
    stop.sh)
      echo "stop"
      ;;
    *)
      echo ""
      ;;
  esac
}

start_server() {
  if [ -f "${PID_FILE}" ]; then
    PID=$(cat "${PID_FILE}")
    if kill -0 "${PID}" 2>/dev/null; then
      echo "[${APP_NAME}] Already running (PID: ${PID})"
      exit 0
    fi
  fi

  mkdir -p "${LOG_DIR}" "${BASE_DIR}/run"

  nohup java "${JAVA_OPTS[@]}" -jar "${JAR_PATH}" \
    > "${LOG_DIR}/${APP_NAME}.out" 2>&1 &

  echo $! > "${PID_FILE}"
  echo "[${APP_NAME}] Started (PID: $!)"
}

stop_server() {
  if [ ! -f "${PID_FILE}" ]; then
    echo "[${APP_NAME}] PID file not found - not running?"
    exit 0
  fi

  PID=$(cat "${PID_FILE}")

  if kill -0 "${PID}" 2>/dev/null; then
    kill "${PID}"
    rm -f "${PID_FILE}"
    echo "[${APP_NAME}] Stopped (PID: ${PID})"
  else
    echo "[${APP_NAME}] Process not found - removing stale PID file"
    rm -f "${PID_FILE}"
  fi
}

COMMAND="$(resolve_command "$@")"

case "${COMMAND}" in
  start)
    start_server
    ;;
  stop)
    stop_server
    ;;
  *)
    print_usage
    exit 1
    ;;
esac
