#!/bin/bash
# Generated by go-deployer — do not edit manually

APP_NAME="{{ .AppName }}"
BASE_DIR="{{ .BaseDir }}"
PID_FILE="${BASE_DIR}/run/${APP_NAME}.pid"

if [ ! -f "${PID_FILE}" ]; then
  echo "[${APP_NAME}] PID file not found — not running?"
  exit 0
fi

PID=$(cat "${PID_FILE}")

if kill -0 "${PID}" 2>/dev/null; then
  kill "${PID}"
  rm -f "${PID_FILE}"
  echo "[${APP_NAME}] Stopped (PID: ${PID})"
else
  echo "[${APP_NAME}] Process not found — removing stale PID file"
  rm -f "${PID_FILE}"
fi
