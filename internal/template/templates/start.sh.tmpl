#!/bin/bash
# Generated by go-deployer — do not edit manually

APP_NAME="{{ .AppName }}"
JAR_PATH="{{ .JarPath }}"
BASE_DIR="{{ .BaseDir }}"
LOG_DIR="${BASE_DIR}/logs"
PID_FILE="${BASE_DIR}/run/${APP_NAME}.pid"
PORT="{{ .Port }}"

JAVA_OPTS=(
  "-Xms{{ .JvmMin }}"
  "-Xmx{{ .JvmMax }}"
  "-Dserver.port=${PORT}"
{{- range .JavaOpts }}
  "{{ . }}"
{{- end }}
{{- range .ExtraOpts }}
  "{{ . }}"
{{- end }}
)

if [ -f "${PID_FILE}" ]; then
  PID=$(cat "${PID_FILE}")
  if kill -0 "${PID}" 2>/dev/null; then
    echo "[${APP_NAME}] Already running (PID: ${PID})"
    exit 0
  fi
fi

mkdir -p "${LOG_DIR}" "${BASE_DIR}/run"

nohup java "${JAVA_OPTS[@]}" -jar "${JAR_PATH}" \
  > "${LOG_DIR}/${APP_NAME}.out" 2>&1 &

echo $! > "${PID_FILE}"
echo "[${APP_NAME}] Started (PID: $!)"
